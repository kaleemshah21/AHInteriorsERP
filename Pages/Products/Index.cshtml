@page
@model AHInteriorsERP.Pages.Products.IndexModel

@{
    ViewData["Title"] = "Products";
}

<h1>Products</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Add Product</a>
</p>

<form method="get" class="mb-3 d-flex gap-2">
    <input asp-for="SearchString" class="form-control" placeholder="Search by product name, SKU, or location" />
    <input type="hidden" name="sortOrder" value="@Model.SortOrder" />
    <button type="submit" class="btn btn-outline-secondary">Search</button>
    <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>SKU</th>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.NameSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Product
                    </a>
                </th>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.PriceSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Price
                    </a>
                </th>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.StockSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Stock
                    </a>
                </th>
                <th>Reserved</th>
                <th>Available</th>
                <th>Location</th>
                <th class="actions"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Products != null && Model.Products.Any())
            {
                foreach (var item in Model.Products)
                {
                    <tr>
                        <td>@item.SKU</td>
                        <td>@item.ProductName</td>
                        <td>£@item.BasePrice.ToString("0.00")</td>
                        <td>@item.StockQuantity</td>
                        <td>@item.ReservedQuantity</td>
                        <td>@item.AvailableQuantity</td>
                        <td>@item.LocationCode</td>
                        <td class="actions">
                            <a asp-page="./Edit" asp-route-id="@item.ProductID">Edit</a> |
                            <a asp-page="./Details" asp-route-id="@item.ProductID">Details</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">No products found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var prevDisabled = (Model.Products == null || !Model.Products.HasPreviousPage) ? "disabled" : "";
    var nextDisabled = (Model.Products == null || !Model.Products.HasNextPage) ? "disabled" : "";
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <a asp-page="./Index"
       asp-route-sortOrder="@Model.SortOrder"
       asp-route-currentFilter="@Model.CurrentFilter"
       asp-route-pageIndex="@((Model.Products?.PageIndex ?? 1) - 1)"
       class="btn btn-outline-primary @prevDisabled">
        Previous
    </a>

    <span>Page @(Model.Products?.PageIndex ?? 1) of @(Model.Products?.TotalPages ?? 1)</span>

    <a asp-page="./Index"
       asp-route-sortOrder="@Model.SortOrder"
       asp-route-currentFilter="@Model.CurrentFilter"
       asp-route-pageIndex="@((Model.Products?.PageIndex ?? 1) + 1)"
       class="btn btn-outline-primary @nextDisabled">
        Next
    </a>
</div>