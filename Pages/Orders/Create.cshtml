@page
@using AHInteriorsERP.Models
@model AHInteriorsERP.Pages.Orders.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Order</h4>
<hr />

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <!-- LEFT SIDE -->
        <div class="col-md-4">
            <div class="form-group">
                <label class="control-label">Customer</label>
                <select asp-for="Order.CustomerID" class="form-control" asp-items="ViewBag.CustomerID">
                    <option value="">-- Select existing customer --</option>
                </select>
                <span asp-validation-for="Order.CustomerID" class="text-danger"></span>
            </div>

            <div class="form-check mt-3 mb-3">
                <input asp-for="CreateNewCustomer" class="form-check-input" id="createNewCustomerCheck" />
                <label asp-for="CreateNewCustomer" class="form-check-label">
                    Create new customer
                </label>
            </div>

            <!-- NEW CUSTOMER -->
            <div id="newCustomerSection">
                <h5>New Customer</h5>

                <div class="form-group mb-2">
                    <label asp-for="NewCustomer.CustomerName"></label>
                    <span class="text-danger">*</span>
                    <input asp-for="NewCustomer.CustomerName" class="form-control" />
                    <span asp-validation-for="NewCustomer.CustomerName" class="text-danger"></span>
                </div>

                <div class="form-group mb-2">
                    <label asp-for="NewCustomer.Phone"></label>
                    <span class="text-danger">*</span>
                    <input asp-for="NewCustomer.Phone" class="form-control" type="tel" />
                    <span asp-validation-for="NewCustomer.Phone" class="text-danger"></span>
                </div>

                <div class="form-group mb-2">
                    <label asp-for="NewCustomer.Email"></label>
                    <input asp-for="NewCustomer.Email" class="form-control" type="email" />
                    <span asp-validation-for="NewCustomer.Email" class="text-danger"></span>
                </div>

                <div class="form-group mb-2">
                    <label asp-for="NewCustomer.AddressLine1"></label>
                    <span class="text-danger">*</span>
                    <input asp-for="NewCustomer.AddressLine1" class="form-control" />
                    <span asp-validation-for="NewCustomer.AddressLine1" class="text-danger"></span>
                </div>

                <div class="form-group mb-2">
                    <label asp-for="NewCustomer.AddressLine2"></label>
                    <input asp-for="NewCustomer.AddressLine2" class="form-control" />
                    <span asp-validation-for="NewCustomer.AddressLine2" class="text-danger"></span>
                </div>

                <div class="form-group mb-2">
                    <label asp-for="NewCustomer.City"></label>
                    <span class="text-danger">*</span>
                    <input asp-for="NewCustomer.City" class="form-control" />
                    <span asp-validation-for="NewCustomer.City" class="text-danger"></span>
                </div>

                <div class="form-group mb-2">
                    <label asp-for="NewCustomer.Postcode"></label>
                    <span class="text-danger">*</span>
                    <input asp-for="NewCustomer.Postcode" class="form-control" />
                    <span asp-validation-for="NewCustomer.Postcode" class="text-danger"></span>
                </div>
            </div>

            <!-- NOTES -->
            <div class="form-group mt-3">
                <label asp-for="Order.Notes"></label>
                <input asp-for="Order.Notes" class="form-control" />
                <span asp-validation-for="Order.Notes" class="text-danger"></span>
            </div>
        </div>

        <!-- RIGHT SIDE (PRODUCTS) -->
        <div class="col-md-8">
            <h5 class="mb-2">Products</h5>
            <p class="text-muted">Enter quantities for one or more products.</p>

            <div class="products-scroll">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>SKU</th>
                                <th>Product</th>
                                <th class="text-end">Price</th>
                                <th class="text-end">Stock</th>
                                <th class="text-end">Reserved</th>
                                <th class="text-end">Available</th>
                                <th class="text-end" style="width:160px;">Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Products.Count; i++)
                            {
                                <tr>
                                    <td>
                                        @Model.Products[i].SKU
                                        <input type="hidden" asp-for="Items[i].ProductID" value="@Model.Products[i].ProductID" />
                                    </td>
                                    <td>@Model.Products[i].ProductName</td>
                                    <td class="text-end">£@Model.Products[i].BasePrice.ToString("0.00")</td>
                                    <td class="text-end">@Model.Products[i].StockQuantity</td>
                                    <td class="text-end">@Model.Products[i].ReservedQuantity</td>
                                    <td class="text-end">@Model.Products[i].AvailableQuantity</td>
                                    <td class="text-end">
                                        <input asp-for="Items[i].Quantity" class="form-control text-end" />
                                        <span asp-validation-for="Items[i].Quantity" class="text-danger"></span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function toggleCustomerMode() {
            const createNew = document.getElementById("createNewCustomerCheck");
            const newCustomerSection = document.getElementById("newCustomerSection");
            const existingCustomerSelect = document.getElementById("Order_CustomerID");

            if (createNew.checked) {
                newCustomerSection.style.display = "block";
                existingCustomerSelect.disabled = true;
            } else {
                newCustomerSection.style.display = "none";
                existingCustomerSelect.disabled = false;
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const checkbox = document.getElementById("createNewCustomerCheck");
            checkbox.addEventListener("change", toggleCustomerMode);
            toggleCustomerMode();
        });
    </script>
}