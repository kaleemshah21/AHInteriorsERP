@page
@model AHInteriorsERP.Pages.Orders.IndexModel

@{
    ViewData["Title"] = "Orders";
}

<h1>Orders</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New</a>
</p>

<form method="get" class="mb-3 d-flex gap-2">
    <input asp-for="SearchString" class="form-control" placeholder="Search by customer, status, or notes" />
    <input type="hidden" name="sortOrder" value="@Model.SortOrder" />
    <button type="submit" class="btn btn-outline-secondary">Search</button>
    <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.DateSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Order Date
                    </a>
                </th>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.StatusSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Status
                    </a>
                </th>
                <th>Total</th>
                <th>Notes</th>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.CustomerSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Customer
                    </a>
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Order != null && Model.Order.Any())
            {
                foreach (var item in Model.Order)
                {
                    <tr>
                        <td>@item.OrderDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.Status</td>
                        <td>
                            £@(item.OrderItems.Sum(oi => oi.Quantity * oi.UnitPriceAtTime).ToString("0.00"))
                        </td>
                        <td>@item.Notes</td>
                        <td>@item.Customer?.CustomerName</td>
                        <td class="actions">
                            <a asp-page="./Edit" asp-route-id="@item.OrderID">Edit</a> |
                            <a asp-page="./Details" asp-route-id="@item.OrderID">Details</a> |
                            <a asp-page="./Delete" asp-route-id="@item.OrderID">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">No orders found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var prevDisabled = !Model.Order.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.Order.HasNextPage ? "disabled" : "";
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <a asp-page="./Index"
       asp-route-sortOrder="@Model.SortOrder"
       asp-route-currentFilter="@Model.CurrentFilter"
       asp-route-pageIndex="@(Model.Order.PageIndex - 1)"
       class="btn btn-outline-primary @prevDisabled">
        Previous
    </a>

    <span>Page @Model.Order.PageIndex of @Model.Order.TotalPages</span>

    <a asp-page="./Index"
       asp-route-sortOrder="@Model.SortOrder"
       asp-route-currentFilter="@Model.CurrentFilter"
       asp-route-pageIndex="@(Model.Order.PageIndex + 1)"
       class="btn btn-outline-primary @nextDisabled">
        Next
    </a>
</div>