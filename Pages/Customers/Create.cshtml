@page
@model AHInteriorsERP.Pages.Customers.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Customer</h4>
<hr />

<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Customer.CustomerName" class="control-label"></label>
                <span class="text-danger">*</span>
                <input asp-for="Customer.CustomerName" class="form-control" />
                <span asp-validation-for="Customer.CustomerName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Customer.Phone" class="control-label"></label>
                <span class="text-danger">*</span>
                <input asp-for="Customer.Phone" class="form-control" type="tel" />
                <span asp-validation-for="Customer.Phone" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Customer.Email" class="control-label"></label>
                <input asp-for="Customer.Email" class="form-control" type="email" />
                <span asp-validation-for="Customer.Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Customer.AddressLine1" class="control-label"></label>
                <span class="text-danger">*</span>
                <input asp-for="Customer.AddressLine1" class="form-control" />
                <span asp-validation-for="Customer.AddressLine1" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Customer.AddressLine2" class="control-label"></label>
                <input asp-for="Customer.AddressLine2" class="form-control" />
                <span asp-validation-for="Customer.AddressLine2" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Customer.City" class="control-label"></label>
                <span class="text-danger">*</span>
                <input asp-for="Customer.City" class="form-control" />
                <span asp-validation-for="Customer.City" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Customer.Postcode" class="control-label"></label>
                <span class="text-danger">*</span>
                <input asp-for="Customer.Postcode" class="form-control" />
                <span asp-validation-for="Customer.Postcode" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}