@page
@model AHInteriorsERP.Pages.Customers.IndexModel

@{
    ViewData["Title"] = "Customers";
}

<h1>Customers</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New</a>
</p>

<form method="get" class="mb-3 d-flex gap-2">
    <input asp-for="SearchString" class="form-control" placeholder="Search by name, email, phone, or city" />
    <input type="hidden" name="sortOrder" value="@Model.SortOrder" />
    <button type="submit" class="btn btn-outline-secondary">Search</button>
    <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.NameSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Customer Name
                    </a>
                </th>
                <th>Phone</th>
                <th>Email</th>
                <th>Address Line 1</th>
                <th>Address Line 2</th>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.CitySort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        City
                    </a>
                </th>
                <th>Postcode</th>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.CreatedSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Created At
                    </a>
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Customer != null && Model.Customer.Any())
        {
            foreach (var item in Model.Customer)
            {
                <tr>
                    <td>@item.CustomerName</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>@item.AddressLine1</td>
                    <td>@item.AddressLine2</td>
                    <td>@item.City</td>
                    <td>@item.Postcode</td>
                    <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td class="actions">
                        <a asp-page="./Edit" asp-route-id="@item.CustomerID">Edit</a> |
                        <a asp-page="./Details" asp-route-id="@item.CustomerID">Details</a> |
                        <a asp-page="./Delete" asp-route-id="@item.CustomerID">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="9" class="text-center">No customers found.</td>
            </tr>
        }
        </tbody>
    </table>
</div>

@{
    var prevDisabled = !Model.Customer.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.Customer.HasNextPage ? "disabled" : "";
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <a asp-page="./Index"
       asp-route-sortOrder="@Model.SortOrder"
       asp-route-currentFilter="@Model.CurrentFilter"
       asp-route-pageIndex="@(Model.Customer.PageIndex - 1)"
       class="btn btn-outline-primary @prevDisabled">
        Previous
    </a>

    <span>Page @Model.Customer.PageIndex of @Model.Customer.TotalPages</span>

    <a asp-page="./Index"
       asp-route-sortOrder="@Model.SortOrder"
       asp-route-currentFilter="@Model.CurrentFilter"
       asp-route-pageIndex="@(Model.Customer.PageIndex + 1)"
       class="btn btn-outline-primary @nextDisabled">
        Next
    </a>
</div>