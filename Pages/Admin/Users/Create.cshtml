@page
@model AHInteriorsERP.Pages.Admin.Users.CreateModel

<h1>Add User</h1>

<form method="post">
    <!-- Display Identity errors and other validation errors -->
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="form-group">
        <label>Email</label>
        <input asp-for="Input.Email" class="form-control" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Password</label>
        <input asp-for="Input.Password" type="password" class="form-control" />
        <span asp-validation-for="Input.Password" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Role</label>
        <select asp-for="Input.Role" class="form-control">
            @foreach (var role in Model.Roles)
            {
                <option value="@role">@role</option>
            }
        </select>
        <span asp-validation-for="Input.Role" class="text-danger"></span>
    </div>

    <button class="btn btn-primary">Create</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}