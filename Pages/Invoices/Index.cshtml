@page
@model AHInteriorsERP.Pages.Invoices.IndexModel

@{
    ViewData["Title"] = "Invoices";
}

<h1>Invoices</h1>

<form method="get" class="mb-3 d-flex gap-2">
    <input asp-for="SearchString" class="form-control" placeholder="Search by invoice number, order ID, or customer" />
    <input type="hidden" name="sortOrder" value="@Model.SortOrder" />
    <button type="submit" class="btn btn-outline-secondary">Search</button>
    <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.NumberSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Invoice Number
                    </a>
                </th>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.DateSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Invoice Date
                    </a>
                </th>
                <th>
                    <a asp-page="./Index"
                       asp-route-sortOrder="@Model.TotalSort"
                       asp-route-currentFilter="@Model.CurrentFilter">
                        Total Amount
                    </a>
                </th>
                <th>Order ID</th>
                <th>Customer</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Invoice != null && Model.Invoice.Any())
            {
                foreach (var item in Model.Invoice)
                {
                    <tr>
                        <td>@item.InvoiceNumber</td>
                        <td>@item.InvoiceDate.ToString("dd/MM/yyyy")</td>
                        <td>£@item.TotalAmount.ToString("0.00")</td>
                        <td>@item.OrderID</td>
                        <td>@item.Order?.Customer?.CustomerName</td>
                        <td>
                            <a asp-page="./Details" asp-route-id="@item.InvoiceID">Details</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">No invoices found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var prevDisabled = (Model.Invoice == null || !Model.Invoice.HasPreviousPage) ? "disabled" : "";
    var nextDisabled = (Model.Invoice == null || !Model.Invoice.HasNextPage) ? "disabled" : "";
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <a asp-page="./Index"
       asp-route-sortOrder="@Model.SortOrder"
       asp-route-currentFilter="@Model.CurrentFilter"
       asp-route-pageIndex="@((Model.Invoice?.PageIndex ?? 1) - 1)"
       class="btn btn-outline-primary @prevDisabled">
        Previous
    </a>

    <span>Page @(Model.Invoice?.PageIndex ?? 1) of @(Model.Invoice?.TotalPages ?? 1)</span>

    <a asp-page="./Index"
       asp-route-sortOrder="@Model.SortOrder"
       asp-route-currentFilter="@Model.CurrentFilter"
       asp-route-pageIndex="@((Model.Invoice?.PageIndex ?? 1) + 1)"
       class="btn btn-outline-primary @nextDisabled">
        Next
    </a>
</div>