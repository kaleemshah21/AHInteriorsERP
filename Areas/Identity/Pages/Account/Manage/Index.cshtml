@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="container-fluid">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-1">@ViewData["Title"]</h1>
            <div class="text-muted">Manage your personal details and contact information.</div>
        </div>
    </div>

    <div class="card p-4" style="max-width: 720px;">
        <partial name="_StatusMessage" for="StatusMessage" />

        <form id="profile-form" method="post" class="mt-2">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" disabled />
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.FirstName" class="form-label"></label>
                    <input asp-for="Input.FirstName" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.LastName" class="form-label"></label>
                    <input asp-for="Input.LastName" class="form-control" />
                </div>
            </div>

            <div class="mt-3">
                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                <input asp-for="Input.PhoneNumber" class="form-control" />
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button id="update-profile-button" type="submit" class="btn btn-primary">
                    Save changes
                </button>

                <a class="btn btn-outline-secondary"
                   asp-page="./ChangePassword">
                    Change password
                </a>

                <a class="btn btn-outline-secondary"
                   asp-page="./Email">
                    Change email
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}